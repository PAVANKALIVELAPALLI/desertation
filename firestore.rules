rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /workflows/{workflowId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.userId == resource.data.userId;
    }

    match /executions/{executionId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false;
    }

    match /executionLogs/{logId} {
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/executions/$(resource.data.executionId))
        && get(/databases/$(database)/documents/executions/$(resource.data.executionId)).data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
